# Database - REQUIRED for backend operation
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5433/ezlove
REDIS_URL=redis://localhost:6380/0

# JWT signing secret - REQUIRED, generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# Set to true only in development
DEBUG=false

# WeChat mini-program credentials (optional, for family features)
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# Anthropic API key (optional, enables AI canteen parsing)
ANTHROPIC_API_KEY=
